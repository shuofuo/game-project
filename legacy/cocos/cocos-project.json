{
  "name": "shengxiao-tianji",
  "version": "1.0.0",
  "game-name": "生肖天机",
  "game-id": "shengxiao_tianji",
  "start-scene": "db://assets/scenes/StartScene.scene",
  "company-name": "shuofuo",
  "product-name": "生肖天机",
  "web-desktop": {
    "start-scene": "assets/scenes/StartScene.scene",
    "merge-classes": true,
    "inline-scopes": ["assets"],
    "platform": "web-desktop",
    "actual-platform": "web-desktop",
    "include": {
      "rules": [
        "assets/scenes/**/*",
        "assets/scripts/**/*",
        "assets/prefabs/**/*",
        "assets/textures/**/*"
      ]
    },
    "exclude": {
      "rules": []
    },
    "mtime-resolution": 0.1,
    "source-maps": false,
    "uglify": true,
    "optimize-fps": false,
    "preview-width": 750,
    "preview-height": 1334,
    "auto-hotreload": true,
    "experiment-auto-atlas": false,
    "pack-config": {
      "inPackTextures": {},
      "outPackTextures": {}
    },
    "packs": {
      "0": [
        "assets/scenes/MainScene.scene",
        "assets/scenes/StartScene.scene",
        "assets/scripts/MainSceneCtrl.ts",
        "assets/scripts/StartSceneCtrl.ts",
        "assets/scripts/Constants.ts",
        "assets/scripts/Types.ts"
      ]
    },
    "test-modle": false,
    "md5Cache": true,
    "use-sonar": false
  },
  "modules": {
    "common": [
      "cc",
      "cc.config",
      "cc.pipeline",
      "cc.rendering",
      "cc.internal"
    ],
    "video": true,
    "webview": true,
    "device": "移动端"
  }
}